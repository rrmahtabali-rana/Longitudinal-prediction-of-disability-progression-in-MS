
# ─── Data: NEVER COMMIT ─────────────────────────────────────────────────────
data/*.xlsx
data/*.xls
data/*.csv
data/*.tsv
data/*.parquet
data/*.feather
data/*.h5
data/*.npz
data/*.pkl
# Keep the documentation file
!data/README.md
!data/.gitkeep

# ─── Pipeline outputs ───────────────────────────────────────────────────────
outputs/
!outputs/.gitkeep

# Per-task output directories at any depth (e.g., during development)
**/task2_outputs/
**/task3_outputs/
**/task4_outputs/
**/task5_outputs/
**/task6_outputs/

# Standalone CSV / image artefacts produced during ad-hoc runs
task*_*.csv
task*_*.xlsx
task*_*.png
task*_*.pdf
task*_*.jpg
fig_*.png
fig_*.pdf

# Don't ignore figures/ that we explicitly want under version control
!figures/**

